# =============== #
#  Unity .gitignore #
# =============== #

# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# TextMeshPro
/[Aa]ssets/TextMesh*Pro/

# ============= #
#    IDE / OS    #
# ============= #

# Visual Studio / Rider / VS Code
.vs/
.vscode/
*.csproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Rider
.idea/
*.sln.iml

# MonoDevelop
*.pidb
*.unityproj

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Gradle (Android)
/[Aa]ssets/Plugins/Android/gradleOut/
.gradle/

# Nuget
*.nupkg
packages/

# Code Coverage
/[Cc]ode[Cc]overage/
